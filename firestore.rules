rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    // Check if user is logged in
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Check if user matches a specific ID
    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Check if user is SuperAdmin
    function isSuperAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }

    // NEW: Check if user is Staff and belongs to a specific owner
    function isStaffOf(ownerId) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn() && 
             userData.role == 'staff' && 
             userData.parentAdminId == ownerId;
    }

    // Check if user OWNS the resource OR is STAFF of the owner
    function hasClubAccess() {
      if (!isSignedIn()) return false;
      let uid = request.auth.uid;
      let ownerId = resource != null ? resource.data.ownerId : request.resource.data.ownerId;
      
      // Case 1: Is Owner
      if (ownerId == uid) return true;
      
      // Case 2: Is Staff of that Owner
      return isStaffOf(ownerId);
    }
    
    // --- Collection Rules ---

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isUser(userId) || isSuperAdmin() || isStaffOf(userId);
      allow create: if isUser(userId) || isSuperAdmin();
      allow write: if isUser(userId) || isSuperAdmin();
    }

    // 2. Rankings (Torneos)
    match /rankings/{rankingId} {
      allow get: if true;
      
      allow list: if (isSignedIn() && (resource.data.ownerId == request.auth.uid || isStaffOf(resource.data.ownerId))) || isSuperAdmin();
      
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      
      allow update, delete: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || 
        isStaffOf(resource.data.ownerId) ||
        isSuperAdmin()
      );

      match /matches/{matchId} {
        allow get: if true;
        
        allow list: if isSignedIn() && (
          get(/databases/$(database)/documents/rankings/$(rankingId)).data.ownerId == request.auth.uid ||
          isStaffOf(get(/databases/$(database)/documents/rankings/$(rankingId)).data.ownerId) ||
          isSuperAdmin()
        );
        
        allow write: if isSignedIn() && (
          get(/databases/$(database)/documents/rankings/$(rankingId)).data.ownerId == request.auth.uid ||
          isStaffOf(get(/databases/$(database)/documents/rankings/$(rankingId)).data.ownerId) ||
          isSuperAdmin()
        );
      }
    }

    // 3. Players
    match /players/{playerId} {
      allow get: if true;
      allow list: if (isSignedIn() && (resource.data.ownerId == request.auth.uid || isStaffOf(resource.data.ownerId))) || isSuperAdmin();
      allow write: if (isSignedIn() && (
        (resource == null && request.resource.data.ownerId == request.auth.uid) || 
        (resource != null && (resource.data.ownerId == request.auth.uid || isStaffOf(resource.data.ownerId)))
      )) || isSuperAdmin();
    }
    
    // 4. Feedback
    match /feedback/{id} {
      allow create: if isSignedIn();
      allow read: if isSuperAdmin();
    }
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
